---
// Background3D.astro - Optimized Shadow Canyon Engine
---
<canvas id="webgl-canvas"></canvas>

<style>
    #webgl-canvas {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        z-index: -1;
        background-color: #050505;
    }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js"></script>

<script is:inline>
    function initShadowCanyon() {
        const canvas = document.querySelector('#webgl-canvas');
        if (!canvas) return;

        const scene = new THREE.Scene();
        
        // 1. Camera
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(15, 18, 15);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); // Limit pixel ratio for performance
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;

        // 2. THE TOPOGRAPHY (FIX: Using InstancedMesh for Performance)
        const size = 12;
        const count = Math.pow(size * 2 + 1, 2);
        const geometry = new THREE.BoxGeometry(0.9, 1, 0.9);
        const material = new THREE.MeshStandardMaterial({ 
            color: 0x1a1a1a, 
            roughness: 0.3,
            metalness: 0.2
        });

        const iMesh = new THREE.InstancedMesh(geometry, material, count);
        iMesh.castShadow = true;
        iMesh.receiveShadow = true;

        const dummy = new THREE.Object3D();
        let i = 0;

        for (let x = -size; x <= size; x++) {
            for (let z = -size; z <= size; z++) {
                const dist = Math.sqrt(x*x + z*z);
                const h = Math.cos(dist * 0.5) * 2 + Math.sin(x * 0.5) * 2 + 3;
                
                // Position the dummy, then set the instance matrix
                dummy.position.set(x, h/2, z);
                dummy.scale.set(1, h, 1);
                dummy.updateMatrix();
                iMesh.setMatrixAt(i++, dummy.matrix);
            }
        }
        scene.add(iMesh);

        // 3. THE LIGHTS
        const ambient = new THREE.AmbientLight(0xffffff, 0.1);
        scene.add(ambient);

        const light = new THREE.PointLight(0x0066ff, 150, 60);
        light.castShadow = true;
        light.shadow.mapSize.set(1024, 1024); // Lowered slightly for performance stability
        light.shadow.bias = -0.001;
        scene.add(light);

        const whiteLight = new THREE.PointLight(0xffffff, 80, 50);
        scene.add(whiteLight);

        // --- CORNER LIGHTS (The Accents) ---
        const cornerIntensity = 150;
        const cornerDist = 60;
        
        // We use the 'size' variable here so lights stay at the grid edges
        const corners = [
            { x:  size - 1, y: 25, z:  size - 1, color: 0xff0055 }, // Hot Pink
            { x: -size + 1, y: 25, z:  size - 1, color: 0x00ffcc }, // Cyan
            { x:  size - 1, y: 25, z: -size + 1, color: 0xffff00 }, // Yellow
            { x: -size, y: -100, z: -size, color: 0x7700ff }  // Purple
        ];

        corners.forEach(c => {
            const cLight = new THREE.PointLight(c.color, cornerIntensity, cornerDist);
            cLight.position.set(c.x, 5, c.z); 
            scene.add(cLight);
        });

        // 4. INTERACTION
        const mouse = new THREE.Vector2();
        const raycaster = new THREE.Raycaster();
        const plane = new THREE.Plane(new THREE.Vector3(0, 1, 0), -2);
        const point = new THREE.Vector3();

        window.addEventListener('mousemove', (e) => {
            mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        // Using window instead of document, and adding both 'mouseleave' and 'mouseout'
        window.addEventListener('mouseleave', () => {
            mouse.x = 0;
            mouse.y = 0;
        });

        // This catches cases where the mouse moves into browser UI or off-screen fast
        window.addEventListener('mouseout', (e) => {
            if (!e.relatedTarget || e.relatedTarget === document.documentElement) {
                mouse.x = 0;
                mouse.y = 0;
            }
        });

        // 5. ANIMATION LOOP
        function animate() {
            requestAnimationFrame(animate);
            
            raycaster.setFromCamera(mouse, camera);
            if (raycaster.ray.intersectPlane(plane, point)) {
                light.position.lerp(new THREE.Vector3(point.x, 6, point.z), 0.05);
                whiteLight.position.lerp(new THREE.Vector3(point.x, 8, point.z), 0.05);
            }
            
            renderer.render(scene, camera);
        }

        // Handle Resizing
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    }

    // Initialize the engine
    initShadowCanyon();

    // Re-init for Astro View Transitions if you use them
    document.addEventListener('astro:after-swap', initShadowCanyon);
</script>