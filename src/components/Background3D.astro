---
// Background3D.astro - Optimized Shadow Canyon Engine
---
<canvas id="webgl-canvas" transition:persist="canyon-bg"></canvas>

<style is:global>
    #webgl-canvas {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        z-index: 0;
        background-color: #050505;
        pointer-events: none;
    }
</style>

<script is:inline>
    // 1. Define Global API IMMEDIATELY so UI buttons never fail
    if (typeof window.mouseLightIsOn === 'undefined') {
        window.mouseLightIsOn = false; // Off by default
    }
    
    window.isMouseLightOn = () => !!window.mouseLightIsOn;
    window.onMouseLightToggle = null; 

    window.setMouseLight = (state) => {
        window.mouseLightIsOn = state;
        if (window.onMouseLightToggle) {
            window.onMouseLightToggle(state);
        }
    };

    function bootShadowCanyon() {
        if (window.shadowCanyonInitialized) return;

        if (typeof THREE === 'undefined') {
            setTimeout(bootShadowCanyon, 50);
            return;
        }

        window.shadowCanyonInitialized = true;

        function initShadowCanyon() {
            const canvas = document.querySelector('#webgl-canvas');
            if (!canvas) return;

            const scene = new THREE.Scene();
            
            const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 150);
            camera.position.set(15, 18, 15);
            camera.lookAt(0, 0, 0);

            const renderer = new THREE.WebGLRenderer({ canvas, antialias: window.innerWidth > 1000 , precision: "mediump", powerPreference: "high-performance"});
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.25)); 
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFShadowMap;

            const size = 35;
            const step = 0.4; 
            const sideCount = Math.floor((size * 2) / step) + 1;
            const count = sideCount * sideCount;
            const geometry = new THREE.BoxGeometry(0.4, 1, 0.4);
            geometry.deleteAttribute('uv');
            
            const material = new THREE.MeshStandardMaterial({ 
                color: 0x050505, 
                roughness: 0.125,
                metalness: 0.9
            });

            const shaderUniforms = {
                uTime: { value: 0 },
                uFocus: { value: new THREE.Vector2(0, 0) }
            };

            material.onBeforeCompile = (shader) => {
                shader.uniforms.uTime = shaderUniforms.uTime;
                shader.uniforms.uFocus = shaderUniforms.uFocus;

                shader.vertexShader = `
                    uniform float uTime;
                    uniform vec2 uFocus;
                    ${shader.vertexShader}
                `;

                shader.vertexShader = shader.vertexShader.replace(
                    `#include <begin_vertex>`,
                    `
                    #include <begin_vertex>
                    
                    float x = instanceMatrix[3][0]; 
                    float z = instanceMatrix[3][2];

                    float dx = x - uFocus.x;
                    float dz = z - uFocus.y;
                    
                    float distFocus = abs(dx) + abs(dz);
                    float angle = atan(dz, dx);
                    
                    float waveA = sin(distFocus * 0.5 - uTime * 15.0 + angle);
                    float waveB = sin(x * 0.2) * cos(z * 0.2); 
                    
                    float waveCombined = abs(waveA * waveB);
                    float smoothHeight = pow(waveCombined, 1.5);
                    
                    float h = (smoothHeight * 14.0) + 0.5;

                    transformed.y *= h; 
                    transformed.y += h / 8.0; 
                    `
                );
            };

            const iMesh = new THREE.InstancedMesh(geometry, material, count);
            iMesh.geometry.computeBoundingSphere();
            iMesh.frustumCulled = true;
            iMesh.castShadow = true;
            iMesh.receiveShadow = true;

            const matrix = new THREE.Matrix4();
            let i = 0;
            for (let xi = 0; xi < sideCount; xi++) {
                for (let zi = 0; zi < sideCount; zi++) {
                    const x = -size + xi * step;
                    const z = -size + zi * step;
                    
                    matrix.setPosition(x, 0, z);
                    iMesh.setMatrixAt(i, matrix);
                    i++;
                }
            }
            
            iMesh.instanceMatrix.needsUpdate = true;
            scene.add(iMesh);

            const ambient = new THREE.AmbientLight(0xffffff, 0.2); 
            scene.add(ambient);

            const light = new THREE.PointLight(0x0A84FF, 1500, 500); 
            light.position.set(0, 6, 0); 
            light.castShadow = true;
            light.shadow.mapSize.set(512, 512);
            light.shadow.bias = -0.001;
            light.visible = window.mouseLightIsOn; 
            scene.add(light);

            const whiteLight = new THREE.PointLight(0xffffff, 400, 300);
            whiteLight.position.set(0, 8, 0);
            whiteLight.visible = window.mouseLightIsOn;
            scene.add(whiteLight);

            const diagDist = size * 0.7; 
            const intensity = 1000;
            const diagonalLights = [
                { x:  diagDist, y: 45, z:  diagDist, color: 0xffffff, int: intensity },
                { x: -diagDist, y: 45, z: -diagDist, color: 0xffffff, int: intensity },
                { x: -diagDist, y: 45, z:  diagDist, color: 0xffffff, int: intensity },
                { x:  diagDist, y: 45, z: -diagDist, color: 0xffffff, int: intensity }, 
                { x: 0, y: 10, z: 0, color: 0xffffff, int:intensity },
                { x: -size, y: 10, z: 10, color: 0xffffff, int:intensity },
                { x: 0, y: 10, z: -size, color: 0xffffff, int:intensity },
                { x: -diagDist, y: 10, z: -1, color: 0xffffff, int:intensity },
                { x: -8, y: 10, z: -diagDist, color: 0xffffff, int:intensity },
                { x: -size, y: 10, z: -size, color: 0xffffff, int:intensity },
                { x: -8, y: 10, z: size / 2, color: 0xffffff, int:intensity },
                { x: size / 5, z: -15, y: 10, color: 0xffffff, int: intensity },
                {x: -20, z: -10, y: 10, color: 0xffffff, int: intensity},
            ];

            diagonalLights.forEach(d => {
                const dLight = new THREE.PointLight(d.color, d.int, 80); 
                dLight.position.set(d.x, d.y, d.z);
                dLight.decay = 1.9;
                scene.add(dLight);
            });

            const rimLight = new THREE.PointLight(0xffffff, 2500, 600);
            rimLight.position.set(0, 70, -size); 
            scene.add(rimLight);

            renderer.toneMapping = THREE.ReinhardToneMapping;
            renderer.toneMappingExposure = 1.8;

            let animationFrameId = null; 
            const clock = new THREE.Clock();

            function requestRender() {
                if (!animationFrameId) {
                    clock.getDelta(); 
                    animate();
                }
            }

            const mouse = new THREE.Vector2();
            const raycaster = new THREE.Raycaster();
            const plane = new THREE.Plane(new THREE.Vector3(0, 1, 0), -2);
            const point = new THREE.Vector3();
            const targetLightPos = new THREE.Vector3(0, 6, 0);
            const targetWhiteLightPos = new THREE.Vector3(0, 8, 0);
            let mouseMoved = false;

            const onMouseMove = (e) => {
                mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
                mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
                mouseMoved = true; 
                requestRender(); 
            };

            const onMouseLeave = () => {
                mouse.x = 0; mouse.y = 0;
                requestRender();
            };

            window.onMouseLightToggle = (state) => {
                light.visible = state;
                whiteLight.visible = state;

                if (state) {
                    window.addEventListener('mousemove', onMouseMove, { passive: true });
                    window.addEventListener('mouseleave', onMouseLeave);
                    window.addEventListener('mouseout', onMouseLeave);
                } else {
                    window.removeEventListener('mousemove', onMouseMove);
                    window.removeEventListener('mouseleave', onMouseLeave);
                    window.removeEventListener('mouseout', onMouseLeave);
                    
                    targetLightPos.set(0, 6, 0);
                    targetWhiteLightPos.set(0, 8, 0);
                }
                requestRender(); 
            };

            if (window.mouseLightIsOn) {
                window.onMouseLightToggle(true);
            }

            // Mobile Touch Handlers
            const onTouchMove = (e) => {
                if (e.touches.length > 0) {
                    mouse.x = (e.touches[0].clientX / window.innerWidth) * 2 - 1;
                    mouse.y = -(e.touches[0].clientY / window.innerHeight) * 2 + 1;
                    mouseMoved = true; 
                    requestRender(); 
                }
            };

            // Hook up the toggle logic to add/remove listeners
            window.onMouseLightToggle = (state) => {
                light.visible = state;
                whiteLight.visible = state;

                if (state) {
                    // Mouse Listeners
                    window.addEventListener('mousemove', onMouseMove, { passive: true });
                    window.addEventListener('mouseleave', onMouseLeave);
                    window.addEventListener('mouseout', onMouseLeave);
                    
                    // Touch Listeners (passive: true ensures we don't block page scrolling)
                    window.addEventListener('touchstart', onTouchMove, { passive: true });
                    window.addEventListener('touchmove', onTouchMove, { passive: true });
                    window.addEventListener('touchend', onMouseLeave, { passive: true });
                    window.addEventListener('touchcancel', onMouseLeave, { passive: true });
                } else {
                    // Remove Mouse Listeners
                    window.removeEventListener('mousemove', onMouseMove);
                    window.removeEventListener('mouseleave', onMouseLeave);
                    window.removeEventListener('mouseout', onMouseLeave);
                    
                    // Remove Touch Listeners
                    window.removeEventListener('touchstart', onTouchMove);
                    window.removeEventListener('touchmove', onTouchMove);
                    window.removeEventListener('touchend', onMouseLeave);
                    window.removeEventListener('touchcancel', onMouseLeave);
                    
                    // Reset Light Position
                    targetLightPos.set(0, 6, 0);
                    targetWhiteLightPos.set(0, 8, 0);
                }
                requestRender(); 
            };

            let targetSpeed = 0;   
            let currentSpeed = 0;  
            let shaderTime = 0;    

            let framesRendered = 0;

            window.playShadowCanyon = (play) => {
                targetSpeed = play ? 1 : 0;
                requestRender(); 
            };

            window.isCanyonPlaying = () => {
                return targetSpeed === 1;
            };

            function animate() {
                framesRendered++;
                const delta = Math.min(clock.getDelta(), 0.1); 
                
                const engineLerp = Math.min(3.0 * delta, 1.0);
                currentSpeed += (targetSpeed - currentSpeed) * engineLerp;
                
                if (targetSpeed === 0 && currentSpeed < 0.005) {
                    currentSpeed = 0;
                }

                shaderTime += (0.05 * delta) * currentSpeed;
                shaderUniforms.uTime.value = shaderTime;
                shaderUniforms.uFocus.value.set(
                    Math.sin(shaderTime * 5) * 3, 
                    Math.cos(shaderTime * 5) * 3
                );

                let isLightMoving = false;
                
                if (window.mouseLightIsOn) {
                    if (mouseMoved) {
                        raycaster.setFromCamera(mouse, camera);
                        if (raycaster.ray.intersectPlane(plane, point)) {
                            targetLightPos.set(point.x, 3, point.z);
                            targetWhiteLightPos.set(point.x, 4, point.z);
                        }
                        mouseMoved = false;
                    }

                    const lightDistSq = light.position.distanceToSquared(targetLightPos);
                    isLightMoving = lightDistSq > 0;

                    if (lightDistSq > 0 && lightDistSq < 0.005) {
                        light.position.copy(targetLightPos);
                        whiteLight.position.copy(targetWhiteLightPos);
                    } else if (lightDistSq > 0) {
                        const lightLerp = Math.min(4.0 * delta, 1.0);
                        light.position.lerp(targetLightPos, lightLerp);
                        whiteLight.position.lerp(targetWhiteLightPos, lightLerp);
                    }
                }

                renderer.render(scene, camera);

                const isEngineActive = targetSpeed > 0 || currentSpeed > 0;

                if (!isEngineActive && !isLightMoving && framesRendered > 300) {
                    animationFrameId = null;
                    return; 
                }

                animationFrameId = requestAnimationFrame(animate);
            }

            let resizeTimeout;
            window.addEventListener('resize', () => {
                if (resizeTimeout) clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(() => {
                    camera.aspect = window.innerWidth / window.innerHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(window.innerWidth, window.innerHeight);
                    requestRender(); 
                }, 100);
            }, { passive: true });

            requestRender(); 
        }

        initShadowCanyon();
    }

    bootShadowCanyon();
</script>

<script>
    function syncCanyonUI() {
        const engineBtns = document.querySelectorAll('#engine-btn');
        const mouseBtns = document.querySelectorAll('#mouse-light-btn');

        if (typeof window.isCanyonPlaying === 'function') {
            const isPlaying = window.isCanyonPlaying();
            engineBtns.forEach(btn => {
                btn.innerText = isPlaying ? "Pause Animation" : "Start Animation";
            });
        }

        if (typeof window.isMouseLightOn === 'function') {
            const isLightOn = window.isMouseLightOn();
            mouseBtns.forEach(btn => {
                btn.innerText = isLightOn ? "Disable Mouse Light" : "Enable Mouse Light";
            });
        }
    }

    function setupGlassCardTouch() {
        const glassCards = document.querySelectorAll('.glass-card');
        
        glassCards.forEach(card => {
            card.addEventListener('touchstart', () => {
                card.classList.add('touch-active');
            }, { passive: true });

            card.addEventListener('touchend', () => {
                card.classList.remove('touch-active');
            }, { passive: true });
            
            card.addEventListener('touchcancel', () => {
                card.classList.remove('touch-active');
            }, { passive: true });
        });
    }

    syncCanyonUI();

    document.addEventListener('astro:page-load', () => {
        syncCanyonUI();
        setupGlassCardTouch(); 
    });
    
    document.addEventListener('astro:after-swap', syncCanyonUI);

    document.addEventListener('click', (e) => {
        const engineBtn = e.target.closest('#engine-btn');
        if (engineBtn && typeof window.isCanyonPlaying === 'function') {
            window.playShadowCanyon(!window.isCanyonPlaying());
            syncCanyonUI(); 
            return;
        }

        const mouseBtn = e.target.closest('#mouse-light-btn');
        if (mouseBtn && typeof window.isMouseLightOn === 'function') {
            window.setMouseLight(!window.isMouseLightOn());
            syncCanyonUI(); 
        }
    });
</script>