---
// Background3D.astro - Optimized Shadow Canyon Engine
---
<canvas id="webgl-canvas"></canvas>

<style>
    #webgl-canvas {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        z-index: -1;
        background-color: #050505;
    }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js"></script>

<script is:inline>
    function initShadowCanyon() {
        const canvas = document.querySelector('#webgl-canvas');
        if (!canvas) return;

        const scene = new THREE.Scene();
        
        // 1. Camera
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(15, 18, 15);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); 
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;

        // 2. THE TOPOGRAPHY (Instanced Mesh Setup)
        const size = 35;
        const step = 0.4; 
        const sideCount = Math.floor((size * 2) / step) + 1;
        const count = sideCount * sideCount;
        const geometry = new THREE.BoxGeometry(0.4, 1, 0.4);
        
        const material = new THREE.MeshStandardMaterial({ 
            color: 0x050505, 
            roughness: 0.15,
            metalness: 0.9
        });

        // --- THE SHADER INJECTION ---
        // These are the variables we will pass from JavaScript to the GPU every frame
        const shaderUniforms = {
            uTime: { value: 0 },
            uFocus: { value: new THREE.Vector2(0, 0) }
        };

        material.onBeforeCompile = (shader) => {
            shader.uniforms.uTime = shaderUniforms.uTime;
            shader.uniforms.uFocus = shaderUniforms.uFocus;

            // Add our variables to the top of the GPU shader
            shader.vertexShader = `
                uniform float uTime;
                uniform vec2 uFocus;
                ${shader.vertexShader}
            `;

            // Replace the standard GPU position logic with our wave math!
            shader.vertexShader = shader.vertexShader.replace(
                `#include <begin_vertex>`,
                `
                #include <begin_vertex>
                
                // instanceMatrix[3] holds the base X, Y, Z of the instanced box
                float x = instanceMatrix[3][0]; 
                float z = instanceMatrix[3][2];

                // The math runs entirely on the GPU now
                float dx = x - uFocus.x;
                float dz = z - uFocus.y;
                
                float distFocus = abs(dx) + abs(dz);
                float angle = atan(dz, dx);
                
                float waveA = sin(distFocus * 0.5 - uTime * 15.0 + angle);
                float waveB = sin(x * 0.2) * cos(z * 0.2); 
                
                float waveCombined = abs(waveA * waveB);
                float smoothHeight = pow(waveCombined, 1.5);
                
                float h = (smoothHeight * 14.0) + 0.5;

                // Scale the Y axis based on height
                transformed.y *= h; 
                // Push it up so it scales from the ground, not the center
                transformed.y += h / 8.0; 
                `
            );
        };

        const iMesh = new THREE.InstancedMesh(geometry, material, count);
        iMesh.castShadow = true;
        iMesh.receiveShadow = true;

        // --- BASE GRID SETUP (Runs only ONCE) ---
        // We lay all 31,000 boxes perfectly flat on the ground. 
        // The shader will handle moving them up and down.
        const matrix = new THREE.Matrix4();
        let i = 0;
        for (let xi = 0; xi < sideCount; xi++) {
            for (let zi = 0; zi < sideCount; zi++) {
                const x = -size + xi * step;
                const z = -size + zi * step;
                
                matrix.setPosition(x, 0, z); // Initial height is 0
                iMesh.setMatrixAt(i, matrix);
                i++;
            }
        }
        // Tell Three.js the matrix is ready
        iMesh.instanceMatrix.needsUpdate = true;
        scene.add(iMesh);

        // --- 3. THE ULTIMATE STUDIO RIG ---
        const ambient = new THREE.AmbientLight(0xffffff, 0.2); 
        scene.add(ambient);

        // Key Light 1 (Casts Shadows)
        const light = new THREE.PointLight(0xffffff, 600, 150);
        light.castShadow = true;
        light.shadow.mapSize.set(1024, 1024); // Dropped to 1024 for VRAM safety
        light.shadow.bias = -0.0001;
        scene.add(light);

        // Key Light 2 (Casts Shadows)
        const whiteLight = new THREE.PointLight(0xe0eaff, 400, 150);
        whiteLight.castShadow = true;
        whiteLight.shadow.mapSize.set(1024, 1024);
        whiteLight.shadow.bias = -0.0001;
        scene.add(whiteLight);

        const diagDist = size * 0.7; 
        const diagonalLights = [
            { x:  diagDist, y: 45, z:  diagDist, color: 0xffffff, int: 1000 },
            { x: -diagDist, y: 45, z: -diagDist, color: 0xffffff, int: 1000 },
            { x: -diagDist, y: 45, z:  diagDist, color: 0xffffff, int: 1000 },
            { x:  diagDist, y: 45, z: -diagDist, color: 0xffffff, int: 1000 }, 
            { x: 0, y: 10, z: 0, color: 0xffffff, int:1000 },
            { x: -size, y: 10, z: 10, color: 0xffffff, int:1000 },
            { x: 0, y: 10, z: -size, color: 0xffffff, int:1000 },
            { x: -diagDist, y: 10, z: -1, color: 0xffffff, int:1000 },
            { x: -8, y: 10, z: -diagDist, color: 0xffffff, int:1000 },
            { x: -size, y: 10, z: -size, color: 0xffffff, int:1000 },
            { x: -8, y: 10, z: size / 2, color: 0xffffff, int:1000 },
            { x: size / 5, z: -15, y: 10, color: 0xffffff, int: 1000 },
            //{ x: -size / 5, z: 5, y: -size / 5, color: 0xffffff, int: 1000 },
            //{x: 10, z: 10, y: 10, color: 0xffffff, int: 1000},
            {x: -20, z: -10, y: 10, color: 0xffffff, int: 1000},
        ];

        // Fill Lights (NO SHADOWS!)
        diagonalLights.forEach(d => {
            const dLight = new THREE.PointLight(d.color, d.int, 400); 
            dLight.position.set(d.x, d.y, d.z);
            dLight.decay = 1.9;
            scene.add(dLight);
        });

        // The Master Rim Light
        const rimLight = new THREE.PointLight(0xffffff, 2500, 600);
        rimLight.position.set(0, 70, -size); 
        scene.add(rimLight);

        renderer.toneMapping = THREE.ReinhardToneMapping;
        renderer.toneMappingExposure = 1.8;

        // 4. INTERACTION
        const mouse = new THREE.Vector2();
        const raycaster = new THREE.Raycaster();
        const plane = new THREE.Plane(new THREE.Vector3(0, 1, 0), -2);
        const point = new THREE.Vector3();

        window.addEventListener('mousemove', (e) => {
            mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        window.addEventListener('mouseleave', () => {
            mouse.x = 0; mouse.y = 0;
        });

        window.addEventListener('mouseout', (e) => {
            if (!e.relatedTarget || e.relatedTarget === document.documentElement) {
                mouse.x = 0; mouse.y = 0;
            }
        });

        // --- 5. THE NEW ULTRA-LIGHTWEIGHT ANIMATION LOOP ---
        function animate() {
            requestAnimationFrame(animate);
    
            const time = performance.now() * 0.000075; 
            
            // Just update the two variables for the GPU
            shaderUniforms.uTime.value = time;
            shaderUniforms.uFocus.value.set(
                Math.sin(time * 5) * 3, 
                Math.cos(time * 5) * 3
            );

            // Interaction Light logic
            raycaster.setFromCamera(mouse, camera);
            if (raycaster.ray.intersectPlane(plane, point)) {
                light.position.lerp(new THREE.Vector3(point.x, 6, point.z), 0.05);
                whiteLight.position.lerp(new THREE.Vector3(point.x, 8, point.z), 0.05);
            }
            
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    }

    initShadowCanyon();
    document.addEventListener('astro:after-swap', initShadowCanyon);
</script>