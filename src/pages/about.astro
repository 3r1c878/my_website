---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Background3D from '../components/Background3D.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Import your hero image if you still want to display it
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            /* Essential for the 3D Background to be visible */
            body, main {
                background: transparent !important;
            }
            main {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 3em 1em;
                position: relative;
                z-index: 1; /* Content stays above cubes */
                color: white;
            }
            .hero-image {
                width: 100%;
                margin-bottom: 2rem;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
            }
        </style>
    </head>
    <body>
        <Background3D />
        <Header />
        
        <main>
            <div class="hero-image">
                <Image width={1020} height={510} src={AboutHeroImage} alt="About Me" />
            </div>

            <h1>Who am I?</h1>
            
            <p>
                I am 20 years old, a second-semester <strong>computer science student at ETH Zurich</strong> 
                and currently working on building a great coding foundation. I enjoy working on 
                theoretical problems and plan on building some cool machine learning or 
                low-level systems projects soon :).
            </p>

            <p>
                In my free time I love playing soccer, going to the gym and playing Cyberpunk 2077.
            </p>

            <p>
                Feel free to message me: 
                <a href="mailto:ericosborn.work@gmail.com" style="color: var(--accent-dark);">
                    ericosborn.work@gmail.com
                </a>
            </p>
        </main>

        <Footer />
    </body>
</html>