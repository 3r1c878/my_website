---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Background3D from '../components/Background3D.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Analytics from '@vercel/analytics/astro';

// Import your hero image if you still want to display it
import AboutHeroImage from '../assets/picture_me.jpg';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
        <style>
            /* Essential for the 3D Background to be visible */
            body, main {
                background: transparent !important;
            }
            main {
                width: 820px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 3em 1em;
                position: relative;
                z-index: 1; /* Content stays above cubes */
                color: white;
            }
            
            .hero-image {
                width: 100%;
                margin-bottom: 2rem;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 32px;
            }
        </style>
    </head>
    <body>
        <Background3D />
        <Header />
        
        <main>
            <section class="glass-card">
                <div class="hero-image">
                    <Image width={1020} height={1020} src={AboutHeroImage} alt="About Me" />
                </div>

                <h1>Who am I?</h1>
                
                <p>
                    I am 20 years old, a second-semester <strong>computer science student at ETH Zurich</strong> 
                    and currently working on building a great coding foundation. I enjoy working on 
                    theoretical problems and plan on building some cool machine learning or 
                    low-level systems projects soon :)
                </p>

                <p>
                    In my free time I love playing soccer, tennis and Cyberpunk 2077.
                </p>

                <p>
                    Feel free to message me: 
                    <a href="mailto:ericosborn.work@gmail.com" style="color: var(--accent-dark);">
                        ericosborn.work@gmail.com
                    </a>
                    <br>Let's connect on 
                    <a href="https://linkedin.com/in/eric-osborn-555aa2305" style="color: var(--accent-dark);">
                        LinkedIn
                    </a>
                </p>
            </section>
        </main>

        <Footer />
		<Analytics />
    </body>
</html>

<style>

    /* --- 1. THE FULL-SCREEN RESET (Fixes iPhone White Borders) --- */
    html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        background-color: #050505;
        overscroll-behavior-y: none; /* Kills the scroll bounce */
    }
    /* Essential: Keep the canvas visible */
    body {
        background-color: #050505; 
        margin: 0;
    }

    main {
        /* Your original layout logic */
        width: 820px;
        max-width: calc(100% - 2em);
        margin: 4rem auto;
        position: relative;
        z-index: 1;

        
        /*background: rgba(10, 10, 10, 0.4);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);*/
        
        /*
        border-radius: 32px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 3rem;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        */
        color: white;
    }

    .glass-card {
        box-sizing: border-box; 
        width: 100%;            
        margin: 0 auto;
        
        max-width: 820px;
        padding: 3rem;
        text-align: center;
        z-index: 1;
        view-transition-name: main-glass;

        /* 2. Force the GPU to render the blur immediately on load */
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        transform: translate3d(0, 0, 0);
        background: rgba(10, 10, 10, 0.4); /* Darker base for better contrast */
        backdrop-filter: blur(20px) saturate(180%); /* Stronger blur + saturation boost */
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        
        border-radius: 32px; /* Large, smooth radius */
        
        border: 1px solid rgba(255, 255, 255, 0.12);

        box-shadow: 
            0 4px 6px -1px rgba(0, 0, 0, 0.3),
            0 20px 25px -5px rgba(0, 0, 0, 0.4),
            inset 0 0 20px rgba(255, 255, 255, 0.02);

        color: white;
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .glass-card:hover {
        /* Lifts the card up 4px, but keeps the GPU acceleration active */
        transform: translateY(-4px) translateZ(0); 
        
        border-color: rgba(0, 150, 255, 0.6); 

        box-shadow: 
            /* 1. SUBTLE INNER FROSTED BLUE */
            inset 0 0 20px 2px rgba(0, 150, 255, 0.15), /* Soft, icy inner haze */
            inset 0 0 5px 1px rgba(0, 150, 255, 0.3),  /* Tiny rim highlight */
            
            /* 2. PROMINENT OUTER FROSTED BLUE */
            0 0 20px 5px rgba(0, 150, 255, 0.3),  /* Tight, bright core of the outer glow */
            0 0 50px 15px rgba(0, 150, 255, 0.2), /* Soft, wide diffusion into the dark background */
            
            /* 3. The physical drop shadows keeping it "lifted" */
            0 10px 15px -3px rgba(0, 0, 0, 0.4),
            0 25px 35px -5px rgba(0, 0, 0, 0.5);
    }
    /* Image Styling */
    .hero-image {
        width: 100%;
        margin-bottom: 2.5rem;
        display: block;
    }
    .hero-image img {
        width: 50%;
        height: auto;
        border-radius: 32px; /* Matching the card's vibe */
        border: 1px solid rgba(255, 255, 255, 0.1);
        opacity: 0.9;
    }

    /* Typography */
    h1 {
        font-size: 3rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.03em;
        background: linear-gradient(to bottom, #ffffff, #a1a1aa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    p {
        line-height: 1.7;
        font-size: 1.15rem;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 1.5rem;
    }

    strong {
        color: #fff;
    }

    /* Link Styling */
    a {
        color: #ffffff;
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.2);
        transition: all 0.3s ease;
    }

    a:hover {
        color: #0066ff; /* Matches your 3D blue accent */
        text-decoration-color: #0066ff;
    }
    @media (max-width: 768px) {
        body {
            font-size: 18px;
        }

        main {
            margin: 1.5rem auto;       
            padding: 1.5rem;           
            border-radius: 20px;       
            width: 100%;               
            max-width: calc(100% - 2rem); 
        }

        .hero-image {
            margin-bottom: 1.5rem;
        }

        .hero-image img {
            border-radius: 12px;       
        }

        /* Forces perfect centering on mobile */
        h1 {
            font-size: 2.2rem;         
            margin-bottom: 1rem;
            text-align: center; 
        }

        p {
            font-size: 1.05rem;        
            line-height: 1.6;
            text-align: center; 
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>