---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Background3D from '../components/Background3D.astro'
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Analytics from '@vercel/analytics/astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Background3D /><Header />
		<main>
			<section class="glass-card">
				<h1>Hi, welcome to my website!</h1>
				<p>
					I am Eric, 20 years old and a CS student at ETH Zurich. I love math, 
                    coding and theoretical problems in CS. Stay tuned for future projects
				</p>
                <p>
                    Hint: Use a 120Hz monitor for an even smoother animation ;)
                </p>

                <button id="engine-btn" class="engine-btn">Start Engine</button>

                <p>
                    Warning: I only recommend running the animation with a good ARM CPU or with a decent dedicated GPU, 
                    since integrated graphics can struggle to animate this.
                </p>
			</section>
		</main>
		<Footer />
		<Analytics />

        <script>
            document.addEventListener('astro:page-load', () => {
                const btn = document.getElementById('engine-btn');
                
                if (btn) {
                    let isPlaying = typeof window.isCanyonPlaying === 'function' ? window.isCanyonPlaying() : false;

                    // Set the correct text immediately when the page loads
                    btn.innerText = isPlaying ? "Pause Engine" : "Start Engine";

                    // Attach the click event to the newly generated button
                    btn.addEventListener('click', () => {
                        isPlaying = !isPlaying; 
                        
                        if (typeof window.playShadowCanyon === 'function') {
                            window.playShadowCanyon(isPlaying);
                        }

                        btn.innerText = isPlaying ? "Pause Engine" : "Start Engine";
                    });
                }
            });
        </script>
	</body>
</html>

<style>
	html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        overscroll-behavior-y: none;

        background-color: transparent;
    }
    main {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80vh; /* Centers the card vertically */
        padding: 2rem;
    }

    .glass-card {
        max-width: 600px;
        padding: 3rem;
        text-align: center;
        
        background: rgba(10, 10, 10, 0.4); /* Darker base for better contrast */
        backdrop-filter: blur(20px) saturate(180%); /* Stronger blur + saturation boost */
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        
        border-radius: 24px; /* Large, smooth radius */
        
        border: 1px solid rgba(255, 255, 255, 0.12);
        view-transition-name: main-glass;

        /* 2. Force the GPU to render the blur immediately on load */
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        transform: translate3d(0, 0, 0);
        box-shadow: 
            0 4px 6px -1px rgba(0, 0, 0, 0.3),
            0 20px 25px -5px rgba(0, 0, 0, 0.4),
            inset 0 0 20px rgba(255, 255, 255, 0.02); /* Very subtle inner glow */

        color: white;
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .glass-card:hover {
        /* Lifts the card up 4px, but keeps the GPU acceleration active */
        transform: translateY(-4px) translateZ(0); 
        
        border-color: rgba(0, 150, 255, 0.6); 

            box-shadow: 
                /* 1. SUBTLE INNER FROSTED BLUE */
                inset 0 0 20px 2px rgba(0, 150, 255, 0.15), /* Soft, icy inner haze */
                inset 0 0 5px 1px rgba(0, 150, 255, 0.3),  /* Tiny rim highlight */
                
                /* 2. PROMINENT OUTER FROSTED BLUE */
                0 0 20px 5px rgba(0, 150, 255, 0.3),  /* Tight, bright core of the outer glow */
                0 0 50px 15px rgba(0, 150, 255, 0.2), /* Soft, wide diffusion into the dark background */
                
                /* 3. The physical drop shadows keeping it "lifted" */
                0 10px 15px -3px rgba(0, 0, 0, 0.4),
                0 25px 35px -5px rgba(0, 0, 0, 0.5);
    }

    h1 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        letter-spacing: -0.02em; /* Tighter tracking looks more professional */
        background: linear-gradient(to bottom, #ffffff, #a1a1aa); /* Subtle text gradient */
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    p {
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.8); /* Slightly dimmed for hierarchy */
        font-size: 1.1rem;
    }

    .engine-btn {
        margin-top: 1.5rem;
        padding: 0.8rem 2.5rem;
        background: rgba(255, 255, 255, 0.05);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 50px; /* Pill shape */
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        backdrop-filter: blur(4px);
        transition: all 0.3s ease;
    }

    /* Matches the hover aesthetic of the main card */
    .engine-btn:hover {
        background: rgba(0, 150, 255, 0.15);
        border-color: rgba(0, 150, 255, 0.6);
        box-shadow: 0 0 15px rgba(0, 150, 255, 0.4);
        transform: translateY(-2px);
    }
	/* --- 3. MOBILE RESPONSIVENESS --- */
    @media (max-width: 768px) {
        main {
            padding: 1rem; /* Less padding on the outside */
            min-height: 75vh; /* Keep it nicely centered vertically */
        }

        .glass-card {
            padding: 2rem 1.5rem; /* Cut the internal padding in half */
            border-radius: 20px;  /* Slightly smaller corner radius */
            width: 100%;          /* Ensure it spans the available space */
        }

        h1 {
            font-size: 2rem;      /* Shrink header to prevent bad text wrapping */
            text-align: center;
        }

        p {
            font-size: 1.05rem;
            text-align: center;
            margin-left: auto;
            margin-right: auto;
        }

        .engine-btn {
            width: 100%; /* Make button full width on mobile */
            margin-top: 1rem;
        }
    }
</style>